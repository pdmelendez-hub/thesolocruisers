  { title: "Explore Alaska on NCL", nights: "7 Nights", date: "Jun 7, 2026", port: "Seattle, WA", ship: "Norwegian Encore", price: "Call for Pricing", destination: "Alaska", img: "/api/photo?q=Alaska+glacier+cruise&orientation=landscape" },
  { title: "Solar Eclipse in Spain", nights: "9 Nights", date: "Aug 7, 2026", port: "Southampton, UK", ship: "Liberty of the Seas", price: "Call for Pricing", destination: "Europe", img: "/api/photo?q=Mediterranean+coast+Spain&orientation=landscape" },
  { title: "Halloween Caribbean", nights: "7 Nights", date: "Oct 25, 2026", port: "Miami, FL", ship: "Allure of the Seas", price: "From $1,039", destination: "Caribbean", img: "/api/photo?q=Caribbean+beach+turquoise+water&orientation=landscape" },
  { title: "Caribbean Christmas & New Year's", nights: "12 Nights", date: "Dec 23, 2026", port: "Miami, FL", ship: "Norwegian Jewel", price: "From $1,978", destination: "Caribbean", img: "/api/photo?q=Caribbean+island+palm+beach&orientation=landscape" },
  { title: "Overnights in Cabo", nights: "7 Nights", date: "Jan 15, 2027", port: "Los Angeles, CA", ship: "Ovation of the Seas", price: "From $628", destination: "Mexican Riviera", img: "/api/photo?q=Cabo+San+Lucas+beach&orientation=landscape" },
  { title: "Full Transit Panama Canal", nights: "15 Nights", date: "Apr 21, 2027", port: "Miami, FL", ship: "Norwegian Joy", price: "From $2,334", destination: "Panama Canal", img: "/api/photo?q=Panama+Canal+ship&orientation=landscape" },
];

const stats = [
  { num: "10,000+", label: "Solo sailors hosted" },
  { num: "200+", label: "Hosted sailings" },
  { num: "4.9★", label: "Average traveler rating" },
  { num: "All Ages", label: "Welcome aboard" },
];

const testimonials = [
  { quote: "The best vacation I have ever taken. Ultimate relaxation and the greatest seven days of my life.", name: "DeeAnn", trip: "Caribbean, 2025" },
  { quote: "I met my fiancée on that cruise. We're so grateful we both took the leap and booked solo.", name: "Jason", trip: "Mediterranean, 2024" },
  { quote: "Beware — it's habit forming, in the best way. This is my fifth sailing and I'm already booking the sixth.", name: "Joni", trip: "Alaska, 2025" },
