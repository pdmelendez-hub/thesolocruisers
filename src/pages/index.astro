  {
    eyebrow: "Specialized Solo Guidance",
    title: "We match you to the right sailing — not just any cruise",
    body: "Solo travel shouldn't mean settling, or paying double. We hand-pick hosted sailings designed for single adults, handle the single-supplement headaches, and make sure you board with a plan and a crew already waiting for you.",
    cta: "Talk to a Solo Specialist",
    img: "https://images.unsplash.com/photo-1488646953014-85cb44e25828?auto=format&fit=crop&w=1100&q=80",
    alt: "Solo traveler looking out over the ocean",
  },
  {
    eyebrow: "A Community That Becomes Family",
    title: "Board as a stranger. Disembark with lifelong friends",
    body: "Every sailing is fully hosted with cocktail mixers, theme nights, shared dining, and excursions built for connection. Our travelers come for the destinations and come back for the people.",
    cta: "See How It Works",
    img: "https://images.unsplash.com/photo-1530103862676-de8c9debad1d?auto=format&fit=crop&w=1100&q=80",
    alt: "Group of friends celebrating together",
  },
  {
    eyebrow: "Expert Destination Insights",
    title: "Firsthand knowledge of every port we sail",
    body: "From Alaska's glaciers to the Mediterranean's hidden coves, we've been there. We'll tell you which excursions are worth it, where to wander on your own, and what to skip.",
    cta: "Explore Destinations",
    img: "https://images.unsplash.com/photo-1533929736458-ca588d08c8be?auto=format&fit=crop&w=1100&q=80",
    alt: "Scenic Mediterranean coastline",
  },
  {
    eyebrow: "Effortless Logistics & Booking",
    title: "Flights, hotels, transfers — handled",
    body: "Need a pre-cruise hotel or airfare? One call and it's done. No spreadsheets, no guesswork, no stress. Just show up and sail.",
