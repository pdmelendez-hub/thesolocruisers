			.divider {
				width: 60px;
				height: 2px;
				background: #7ab8d4;
				margin: 0 auto 2.5rem;
			}

			p {
				font-size: 1.1rem;
				line-height: 1.8;
				color: #b0c8d8;
			}

			.waves {
				margin-top: 3rem;
				font-size: 1.5rem;
				letter-spacing: 0.5rem;
				opacity: 0.4;
			}
