---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>The Solo Cruisers — Sail Solo, Explore Together.</title>
  <meta name="description" content="Hosted cruises for solo travelers. We match single adults to the right sailing, handle the logistics, and connect you with a crew before you ever board." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #14233b;
      --ink-soft: #2a3a52;
      --cream: #faf6ef;
      --cream-deep: #f1e9dc;
      --brass: #b8893f;
      --brass-light: #c8a14e;
      --ocean: #2c7a8c;
      --text: #2a2a28;
      --muted: #6f6f68;
      --line: #e3dccf;
      --white: #ffffff;
    }

    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: var(--cream); line-height: 1.6; }

    h1, h2, h3 { font-family: 'Fraunces', serif; font-weight: 500; line-height: 1.1; color: var(--ink); letter-spacing: -0.01em; }

    .eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--brass); margin-bottom: 1rem; }

    a { color: inherit; }
    img { display: block; max-width: 100%; }

    .wrap { max-width: 1240px; margin: 0 auto; padding: 0 2rem; }

    /* ── REVEAL ── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1); }
    .reveal.in { opacity: 1; transform: none; }

    /* ── ANNOUNCEMENT ── */
    .announce { background: var(--ink); color: var(--cream); text-align: center; font-size: 0.78rem; letter-spacing: 0.04em; padding: 0.55rem 1rem; }
    .announce strong { color: var(--brass-light); font-weight: 600; }

    /* ── NAV ── */
    .nav { position: sticky; top: 0; z-index: 200; transition: background 0.4s, box-shadow 0.4s, padding 0.4s; padding: 1.4rem 0; }
    .nav.solid { background: rgba(250,246,239,0.92); backdrop-filter: blur(12px); box-shadow: 0 1px 0 var(--line); padding: 0.9rem 0; }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
    .brand { display: flex; flex-direction: column; line-height: 1.05; text-decoration: none; }
    .brand-name { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 600; color: var(--ink); }
    .brand-tag { font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--brass); margin-top: 2px; }
    .nav.on-hero:not(.solid) .brand-name { color: var(--cream); }
    .nav.on-hero:not(.solid) .nav-links a { color: rgba(255,255,255,0.9); }
    .nav-links { display: flex; align-items: center; gap: 2rem; }
    .nav-links a { text-decoration: none; font-size: 0.9rem; font-weight: 500; color: var(--ink-soft); transition: color 0.2s; position: relative; }
    .nav-links a:not(.btn)::after { content: ''; position: absolute; left: 0; bottom: -4px; width: 0; height: 1.5px; background: var(--brass); transition: width 0.3s; }
    .nav-links a:not(.btn):hover::after { width: 100%; }
    .btn-pill { background: var(--brass); color: var(--white) !important; padding: 0.6rem 1.4rem; border-radius: 50px; font-weight: 600; font-size: 0.85rem; transition: background 0.25s, transform 0.25s; }
    .btn-pill:hover { background: var(--ink); transform: translateY(-1px); }

    /* ── HERO ── */
    .hero { position: relative; min-height: 92vh; margin-top: -88px; display: flex; align-items: center; overflow: hidden; }
    .hero-img { position: absolute; inset: 0; background: url('/api/photo?q=cruise+ship+ocean+sunset&orientation=landscape') center/cover; animation: kenburns 22s ease-out infinite alternate; }
    @keyframes kenburns { from { transform: scale(1); } to { transform: scale(1.12); } }
    .hero-veil { position: absolute; inset: 0; background: linear-gradient(110deg, rgba(20,35,59,0.78) 0%, rgba(20,35,59,0.45) 50%, rgba(20,35,59,0.25) 100%); }
    .hero-content { position: relative; max-width: 720px; padding-top: 88px; }
    .hero .eyebrow { color: var(--brass-light); }
    .hero h1 { color: var(--cream); font-size: clamp(2.8rem, 6.5vw, 5.4rem); font-weight: 500; }
    .hero h1 em { font-style: italic; color: var(--brass-light); }
    .hero p { color: rgba(255,255,255,0.88); font-size: 1.2rem; max-width: 540px; margin: 1.6rem 0 2.4rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
    .btn-solid { background: var(--brass); color: var(--white); padding: 0.95rem 2.2rem; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: background 0.25s, transform 0.25s; }
    .btn-solid:hover { background: var(--brass-light); transform: translateY(-2px); }
    .btn-ghost { color: var(--cream); text-decoration: none; font-weight: 600; font-size: 0.95rem; padding: 0.95rem 1rem; border-bottom: 1.5px solid transparent; transition: border-color 0.25s; }
    .btn-ghost:hover { border-color: var(--brass-light); }
    .scroll-hint { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.7); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
    .scroll-hint span { width: 1px; height: 40px; background: rgba(255,255,255,0.5); animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 0.3; transform: scaleY(0.6);} 50%{opacity:1;transform:scaleY(1);} }

    /* ── INTRO ── */
    .intro { padding: 7rem 0 4rem; text-align: center; }
    .intro h2 { font-size: clamp(2rem, 4vw, 3.2rem); max-width: 900px; margin: 0 auto 1.5rem; }
    .intro p { font-size: 1.15rem; color: var(--muted); max-width: 640px; margin: 0 auto; }

    /* ── STORY (alternating) ── */
    .story { padding: 4rem 0; }
    .story-row { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5rem; align-items: center; margin-bottom: 7rem; }
    .story-row:last-child { margin-bottom: 0; }
    .story-row.flip .story-text { order: 2; }
    .story-row.flip .story-media { order: 1; }
    .story-media { position: relative; }
    .story-media img { width: 100%; height: 540px; object-fit: cover; border-radius: 4px; }
    .story-media::after { content: ''; position: absolute; inset: 0; border: 1px solid rgba(255,255,255,0.4); border-radius: 4px; transform: translate(16px,16px); z-index: -1; background: var(--cream-deep); }
    .story-text h2 { font-size: clamp(1.8rem, 3vw, 2.6rem); margin-bottom: 1.2rem; }
    .story-text p { color: var(--muted); font-size: 1.05rem; margin-bottom: 1.8rem; }
    .text-link { display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600; font-size: 0.92rem; color: var(--ink); text-decoration: none; border-bottom: 1.5px solid var(--brass); padding-bottom: 3px; transition: gap 0.25s; }
    .text-link:hover { gap: 0.9rem; }

    /* ── STATS ── */
    .stats { background: var(--ink); color: var(--cream); padding: 5rem 0; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center; }
    .stat-num { font-family: 'Fraunces', serif; font-size: clamp(2.2rem, 4vw, 3.4rem); color: var(--brass-light); font-weight: 500; }
    .stat-label { font-size: 0.85rem; letter-spacing: 0.08em; color: rgba(255,255,255,0.7); margin-top: 0.4rem; text-transform: uppercase; }

    /* ── CRUISES ── */
    .cruises { padding: 7rem 0; }
    .section-head { text-align: center; margin-bottom: 3.5rem; }
    .section-head h2 { font-size: clamp(2rem, 4vw, 3rem); }
    .section-head p { color: var(--muted); font-size: 1.1rem; margin-top: 0.8rem; }
    .cruise-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(330px,1fr)); gap: 2rem; }
    .ccard { background: var(--white); border-radius: 6px; overflow: hidden; box-shadow: 0 1px 2px rgba(20,35,59,0.06); transition: transform 0.35s, box-shadow 0.35s; }
    .ccard:hover { transform: translateY(-6px); box-shadow: 0 20px 50px rgba(20,35,59,0.14); }
    .ccard-media { position: relative; height: 230px; overflow: hidden; }
    .ccard-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.16,1,0.3,1); }
    .ccard:hover .ccard-media img { transform: scale(1.06); }
    .ccard-tag { position: absolute; top: 1rem; left: 1rem; background: rgba(250,246,239,0.92); color: var(--ink); font-size: 0.66rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.3rem 0.7rem; border-radius: 50px; }
    .ccard-body { padding: 1.5rem; }
    .ccard-body h3 { font-size: 1.3rem; margin-bottom: 0.8rem; }
    .ccard-meta { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.82rem; color: var(--muted); margin-bottom: 1.2rem; }
    .ccard-meta span { display: inline-flex; align-items: center; gap: 0.3rem; }
    .ccard-foot { display: flex; align-items: center; justify-content: space-between; padding-top: 1.1rem; border-top: 1px solid var(--line); }
    .ccard-price { font-weight: 600; color: var(--ink); font-size: 0.95rem; }
    .ccard-price small { display: block; font-size: 0.68rem; color: var(--muted); font-weight: 400; letter-spacing: 0.04em; }
    .ccard-link { font-size: 0.82rem; font-weight: 600; color: var(--brass); text-decoration: none; border-bottom: 1.5px solid transparent; transition: border-color 0.2s; }
    .ccard-link:hover { border-color: var(--brass); }
    .cruises-foot { text-align: center; margin-top: 3rem; color: var(--muted); font-size: 0.95rem; }

    /* ── TESTIMONIALS ── */
    .quotes { background: var(--cream-deep); padding: 7rem 0; }
    .quotes-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2.5rem; }
    .quote { background: var(--cream); padding: 2.5rem 2rem; border-radius: 6px; position: relative; }
    .quote .mark { font-family: 'Fraunces', serif; font-size: 4rem; line-height: 0.6; color: var(--brass); opacity: 0.35; }
    .quote p { font-family: 'Fraunces', serif; font-style: italic; font-size: 1.15rem; color: var(--ink); margin: 0.5rem 0 1.5rem; line-height: 1.5; }
    .quote .who { font-weight: 600; font-size: 0.9rem; color: var(--ink); }
    .quote .trip { font-size: 0.8rem; color: var(--muted); }

    /* ── CTA ── */
    .cta { position: relative; padding: 8rem 0; text-align: center; overflow: hidden; }
    .cta-img { position: absolute; inset: 0; background: url('/api/photo?q=ocean+horizon+sea+sunset&orientation=landscape') center/cover; }
    .cta-veil { position: absolute; inset: 0; background: rgba(20,35,59,0.7); }
    .cta-content { position: relative; }
    .cta h2 { color: var(--cream); font-size: clamp(2.2rem, 5vw, 3.8rem); max-width: 800px; margin: 0 auto 1.2rem; }
    .cta h2 em { font-style: italic; color: var(--brass-light); }
    .cta p { color: rgba(255,255,255,0.85); font-size: 1.15rem; margin-bottom: 2.4rem; }
    .cta .phone { display: block; margin-top: 1.6rem; color: rgba(255,255,255,0.75); font-size: 0.95rem; }
    .cta .phone a { color: var(--brass-light); font-weight: 600; text-decoration: none; }

    /* ── FOOTER ── */
    footer { background: var(--ink); color: rgba(255,255,255,0.65); padding: 4.5rem 0 2rem; }
    .foot-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
    .foot-brand .brand-name { color: var(--cream); }
    .foot-brand p { margin-top: 1rem; font-size: 0.9rem; line-height: 1.7; color: rgba(255,255,255,0.55); max-width: 320px; }
    .foot-brand .phone { display: block; margin-top: 1rem; color: var(--brass-light); font-weight: 600; text-decoration: none; }
    footer h4 { font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 1.1rem; }
    footer ul { list-style: none; }
    footer li { margin-bottom: 0.6rem; }
    footer li a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
    footer li a:hover { color: var(--cream); }
    .foot-bottom { border-top: 1px solid rgba(255,255,255,0.12); padding-top: 1.6rem; display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; }
    .foot-legal { font-size: 0.72rem; color: rgba(255,255,255,0.35); line-height: 1.7; }
    .foot-links { display: flex; gap: 1.4rem; }
    .foot-links a { font-size: 0.78rem; color: rgba(255,255,255,0.5); text-decoration: none; }
    .foot-links a:hover { color: var(--cream); }

    /* ── RESPONSIVE ── */
    @media (max-width: 940px) {
      .nav-links { display: none; }
      .nav-links.mini { display: flex; gap: 1rem; }
      .story-row { grid-template-columns: 1fr; gap: 2rem; margin-bottom: 4.5rem; }
      .story-row.flip .story-text { order: 1; }
      .story-row.flip .story-media { order: 2; }
      .story-media img { height: 360px; }
      .stats-grid { grid-template-columns: repeat(2,1fr); gap: 2.5rem; }
      .quotes-grid { grid-template-columns: 1fr; }
      .foot-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    }
    @media (max-width: 560px) {
      .wrap { padding: 0 1.4rem; }
      .foot-grid { grid-template-columns: 1fr; }
      .hero p { font-size: 1.05rem; }
    }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
      .hero-img { animation: none; }
      .scroll-hint span { animation: none; }
    }
  </style>
</head>
<body>

  <div class="announce"><strong>Solo Early Savings</strong> — 5% off new group bookings made 6+ months ahead</div>

  <header class="nav on-hero" id="nav">
    <div class="wrap nav-inner">
      <a href="/" class="brand">
        <span class="brand-name">The Solo Cruisers</span>
        <span class="brand-tag">Sail Solo, Explore Together</span>
      </a>
      <nav class="nav-links">
        <a href="#story">Why Us</a>
        <a href="#cruises">Cruises</a>
        <a href="#stories">Stories</a>
        <a href="#contact">Contact</a>
        <a href="#contact" class="btn-pill">Plan Your Voyage</a>
      </nav>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-img"></div>
    <div class="hero-veil"></div>
    <div class="wrap hero-content">
      <p class="eyebrow">Hosted cruises for solo travelers</p>
      <h1>Sail Solo.<br /><em>Explore Together.</em></h1>
      <p>We match single adults to the perfect hosted sailing, handle every logistic, and introduce you to your crew before you ever step aboard.</p>
      <div class="hero-actions">
        <a href="#cruises" class="btn-solid">Browse Cruises</a>
        <a href="#story" class="btn-ghost">How it works →</a>
      </div>
    </div>
    <div class="scroll-hint">Scroll<span></span></div>
  </section>

  <!-- INTRO -->
  <section class="intro wrap reveal">
    <p class="eyebrow">Working with The Solo Cruisers gets you…</p>
    <h2>Travel that feels effortless — and never lonely</h2>
    <p>This isn't a traditional cruise. It's a curated community experience for single adults who want to see the world alongside fun, like-minded travelers. No stress. No guesswork. No single-supplement surprises.</p>
  </section>

  <!-- STORY -->
  <section class="story wrap" id="story">
    {story.map((s, i) => (
      <div class={`story-row reveal ${i % 2 === 1 ? "flip" : ""}`}>
        <div class="story-text">
          <p class="eyebrow">{s.eyebrow}</p>
          <h2>{s.title}</h2>
          <p>{s.body}</p>
          <a href="#contact" class="text-link">{s.cta} →</a>
        </div>
        <div class="story-media">
          <img src={s.img} alt={s.alt} loading="lazy" />
        </div>
      </div>
    ))}
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="wrap stats-grid reveal">
      {stats.map((s) => (
        <div>
          <div class="stat-num">{s.num}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- CRUISES -->
  <section class="cruises wrap" id="cruises">
    <div class="section-head reveal">
      <p class="eyebrow">Upcoming Sailings</p>
      <h2>Hosted group cruises</h2>
      <p>Every sailing is fully hosted — our team is onboard from departure to port.</p>
    </div>
    <div class="cruise-grid">
      {cruises.map((c) => (
        <article class="ccard reveal">
          <div class="ccard-media">
            <img src={c.img} alt={`${c.destination} cruise`} loading="lazy" />
            <span class="ccard-tag">{c.destination}</span>
          </div>
          <div class="ccard-body">
            <h3>{c.title}</h3>
            <div class="ccard-meta">
              <span>◷ {c.nights}</span>
              <span>⚓ {c.port}</span>
              <span>⊹ {c.date}</span>
            </div>
            <div class="ccard-foot">
              <div class="ccard-price">{c.price}<small>{c.ship}</small></div>
              <a href="#contact" class="ccard-link">Request Info →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
    <p class="cruises-foot">Need a pre-cruise hotel or airfare? Call our help desk at <strong>877-485-5313</strong>.</p>
  </section>

  <!-- TESTIMONIALS -->
  <section class="quotes" id="stories">
