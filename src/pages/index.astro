            <span class="cruise-badge">Guaranteed Hosted</span>
            <span class="destination-name">Caribbean</span>
          </div>
          <div class="cruise-card-body">
            <h3 class="cruise-card-title">Halloween Caribbean</h3>
            <div class="cruise-meta">
              <span>7 Nights</span><span>Oct 25, 2026</span><span>Miami, FL</span><span>RC Allure of the Seas</span>
            </div>
